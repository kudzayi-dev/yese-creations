# Root .dockerignore — applies to any `docker build` run from the repo
# root context (both apps/cms/Dockerfile and apps/storefront/Dockerfile
# are built this way; see each Dockerfile's header comment).
node_modules
**/node_modules
.git
.turbo
**/.turbo
.plan
# The other design_handoff_* folders are reference-only, safe to exclude
# from the build context (unlike product-photos/ and brand-assets/ at
# repo root, which are genuine seed-time runtime dependencies — see
# apps/cms/src/scripts/seed.ts).
design_handoff_yese_shop
design_handoff_yese_checkout
design_handoff_yese_newsletter
design_handoff_yese_search
design_handoff_yese_reviews
apps/cms/media
apps/cms/.next
apps/storefront/dist
apps/docs/build
apps/docs/.docusaurus
**/*.tsbuildinfo
out
.DS_Store
**/.DS_Store
.env
.env.*
!.env.example
!**/.env.example
