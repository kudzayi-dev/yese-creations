# Root .dockerignore — applies to any `docker build` run from the repo
# root context (both apps/cms/Dockerfile and apps/storefront/Dockerfile
# are built this way; see each Dockerfile's header comment).
node_modules
**/node_modules
.git
.turbo
**/.turbo
.plan
# design_handoff_yese_shop/assets IS a genuine runtime dependency of
# apps/cms/src/scripts/seed.ts (reads real product photos from there
# directly, not just local reference material — confirmed the hard way:
# `docker compose run migrate pnpm seed` failed with "Seed asset missing"
# until this exception was added). The other design_handoff_* folders
# (checkout/newsletter/search/reviews) really are reference-only and stay
# excluded.
design_handoff_yese_checkout
design_handoff_yese_newsletter
design_handoff_yese_search
design_handoff_yese_reviews
apps/cms/media
apps/cms/.next
apps/storefront/dist
apps/docs/build
apps/docs/.docusaurus
**/*.tsbuildinfo
out
.DS_Store
**/.DS_Store
.env
.env.*
!.env.example
!**/.env.example
