{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env"],
  "globalEnv": [
    "DATABASE_URI",
    "PAYLOAD_SECRET",
    "NEXT_PUBLIC_SERVER_URL",
    "STOREFRONT_URL",
    "CMS_URL",
    "SITE_URL",
    "STRIPE_SECRET_KEY",
    "VITE_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "CMS_SERVICE_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".output/**", ".vinxi/**", "build/**"]
    },
    "@yese/cms#build": {
      "dependsOn": ["^build", "@yese/docs#build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
