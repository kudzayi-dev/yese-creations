# .env.production.example — copy to .env.production on the VPS and fill
# in real values. Referenced by docker-compose.yml via `env_file`.
#
# IMPORTANT: CMS_URL means two DIFFERENT things for the two services below,
# which is why it's split into two separate variables here rather than one
# shared value:
#   - PUBLIC_CMS_URL: the CMS's own public domain. Payload uses this to
#     emit ABSOLUTE media/upload URLs (see payload.config.ts's serverURL) —
#     this must be resolvable from a customer's browser, not just from
#     inside the Docker network.
#   - The storefront talks to the CMS over the internal Docker network
#     (http://cms:3001, hardcoded in docker-compose.yml) for its own
#     server-side data fetches — faster and doesn't round-trip through the
#     public internet/reverse proxy for server-to-server calls. You do NOT
#     set this one here; it's fixed in docker-compose.yml already.

# ---- Postgres ----
POSTGRES_PASSWORD=change-me-generate-a-real-one

# ---- CMS (apps/cms) ----
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-in-production
PUBLIC_CMS_URL=https://cms.yesecreations.com
STOREFRONT_URL=https://www.yesecreations.com

# ---- Shared between CMS and storefront (must match exactly) ----
# Generate with: openssl rand -hex 24
CMS_SERVICE_TOKEN=change-me-shared-with-storefront

# ---- Storefront (apps/storefront) ----
SITE_URL=https://www.yesecreations.com
STRIPE_SECRET_KEY=sk_live_your_real_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_real_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_real_webhook_signing_secret

# ---- Telemetry: Umami (product analytics) ----
# Generate with: openssl rand -base64 32
UMAMI_APP_SECRET=change-me-in-production
# Both of these need the VITE_ prefix to reach the client bundle (same
# reasoning as VITE_STRIPE_PUBLISHABLE_KEY — safe, designed to be public).
# VITE_UMAMI_WEBSITE_ID is generated INSIDE Umami's own dashboard the
# first time you add this site there — you can't know it in advance; set
# up Umami first, then come back and fill this in.
VITE_ANALYTICS_URL=https://analytics.yesecreations.com
VITE_UMAMI_WEBSITE_ID=fill-in-after-first-umami-login
