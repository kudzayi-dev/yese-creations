# CMS origin for server-side product fetches. Never exposed to the client bundle.
# In production, set to the real CMS domain.
CMS_URL=http://localhost:3001

# Public site URL — used for canonical/OG meta tags on PDPs, and as the Stripe
# checkout return_url origin.
SITE_URL=https://www.yesecreations.com

# Stripe — Stage 17 (checkout). Use live keys in production, test keys in dev.
# Secret key: server-only, never bundled client-side.
STRIPE_SECRET_KEY=sk_live_or_test_your_secret_key
# Publishable key: needs the VITE_ prefix to reach the client bundle (safe —
# it's designed to be public).
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
