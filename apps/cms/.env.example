# Postgres connection string for Payload's Drizzle adapter.
# Local dev uses the shared infra Docker Postgres (postgres:16-alpine).
DATABASE_URI=postgresql://postgres:localdev@localhost:5432/yese

# Payload signing secret. Generate a strong random value for real environments,
# e.g. `openssl rand -base64 32`.
PAYLOAD_SECRET=change-me-in-production

# Public origin the CMS is reachable at. Payload uses this to emit absolute media URLs
# so the storefront (:3000) can render images served by the CMS (:3001).
# In production this must be the real CMS domain, not localhost.
CMS_URL=http://localhost:3001

# Storefront origin allowed to fetch the CMS API (CORS).
# In production set to the real storefront domain.
STOREFRONT_URL=http://localhost:3000

# Shared secret letting the storefront's SERVER create/update Orders here
# without an admin session (checked via the x-service-token header in
# collections/Orders.ts). Must match the storefront's copy exactly.
# Generate with `openssl rand -hex 24`.
CMS_SERVICE_TOKEN=change-me-shared-with-storefront
