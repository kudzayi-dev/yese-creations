# Yese Creations — root env reference.
#
# Each app loads its OWN .env from its own directory (apps/cms/.env,
# apps/storefront/.env) — Vite and Next.js both only read .env files from the
# app's cwd, not the monorepo root. This file is not loaded by either app; it
# exists purely as a single place documenting every var across the whole
# stack, and as the thing `pnpm dev`/turbo caching (see turbo.json's
# `globalEnv`) key off of. Copy the values below into apps/cms/.env and
# apps/storefront/.env (or copy their own .env.example files — same content).

# ---------------------------------------------------------------- apps/cms
# Postgres connection string for Payload's Postgres adapter.
DATABASE_URI=postgresql://postgres:localdev@localhost:5432/yese

# Payload signing secret. Generate a real one for anything beyond local dev:
# `openssl rand -base64 32`.
PAYLOAD_SECRET=change-me-in-production

# Public origin the CMS is reachable at. Payload uses this to emit ABSOLUTE
# media URLs (payload.config.ts's `serverURL`) so the storefront (:3000) can
# render images served by the CMS (:3001) — this must be correct even in
# dev, not just production.
CMS_URL=http://localhost:3001

# Storefront origin allowed to call the CMS API (CORS). In production, the
# real storefront domain.
STOREFRONT_URL=http://localhost:3000

# Shared secret that lets the storefront's SERVER (not the browser) create
# and update Orders in the CMS without an admin session — checked via the
# x-service-token header in apps/cms/src/collections/Orders.ts's access
# control. Must be identical here and in apps/storefront's copy below.
# Generate with `openssl rand -hex 24`.
CMS_SERVICE_TOKEN=change-me-shared-with-storefront

# ---------------------------------------------------------- apps/storefront
# Same CMS_URL/SITE_URL values as above, from the storefront's side:
# CMS_URL=http://localhost:3001
# SITE_URL=http://localhost:3000   (used for canonical/OG tags, sitemap.xml
#                                    host, and the Stripe checkout return_url)

# Stripe (Stage 17 — checkout). Test-mode keys for local dev; never commit
# live keys. STRIPE_SECRET_KEY is server-only (never bundled to the client —
# plain, non-VITE_-prefixed vars stay server-side in Vite/TanStack Start).
# STRIPE_SECRET_KEY=sk_test_your_secret_key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret   (from `stripe
#                                                             listen` in dev)

# Same CMS_SERVICE_TOKEN value as apps/cms's copy above — sent as the
# x-service-token header on Orders create/update calls to the CMS.
# CMS_SERVICE_TOKEN=change-me-shared-with-storefront
